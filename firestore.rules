rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // デフォルト拒否
    match /{document=**} {
      allow read, write: if false;
    }

    // 管理者判定（Firebase Auth カスタムクレーム）
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // 予約データバリデーション
    function isValidReservation(data) {
      return data.keys().hasAll(['id','name','furigana','date','time','phone','status','createdAt'])
        && data.name     is string && data.name.size()     <= 50
        && data.furigana is string && data.furigana.size() <= 50
        && data.phone    is string && data.phone.size()    <= 20
        && data.date     is string && data.date.size()     == 10
        && data.time     is string && data.time.size()     <= 10
        && data.status   in ['pending','confirmed','cancelled','completed']
        // 任意フィールドの型・長さ検証
        && (!data.keys().hasAny(['email'])         || (data.email is string && data.email.size() <= 200))
        && (!data.keys().hasAny(['zip'])           || (data.zip is string && data.zip.size() <= 8))
        && (!data.keys().hasAny(['address'])       || (data.address is string && data.address.size() <= 200))
        && (!data.keys().hasAny(['symptoms'])      || (data.symptoms is string && data.symptoms.size() <= 1000))
        && (!data.keys().hasAny(['notes'])         || (data.notes is string && data.notes.size() <= 500))
        && (!data.keys().hasAny(['visitType'])     || (data.visitType is string && data.visitType.size() <= 50))
        && (!data.keys().hasAny(['insurance'])     || (data.insurance is string && data.insurance.size() <= 50))
        && (!data.keys().hasAny(['gender'])        || (data.gender is string && data.gender.size() <= 20))
        && (!data.keys().hasAny(['birthdate'])     || (data.birthdate is string && data.birthdate.size() <= 10))
        && (!data.keys().hasAny(['contactMethod']) || (data.contactMethod is string && data.contactMethod.size() <= 50))
        // [C1] 要配慮個人情報の同意フラグ（個人情報保護法 第20条第2項）
        && (!data.keys().hasAny(['hasSensitiveDataConsent']) || (data.hasSensitiveDataConsent is bool))
        // [H2] リマインダーメール配信同意
        && (!data.keys().hasAny(['reminderEmailConsent']) || (data.reminderEmailConsent is bool));
    }

    // [SEC-18] create は Cloud Function (createReservation) 経由のみ
    // [SEC-5]  cancel も Cloud Function (cancelReservation) 経由のみ
    // [SEC-3]  get も Cloud Function (verifyReservation) 経由のみ — 未認証アクセス完全廃止
    match /reservations/{reservationId} {
      allow read: if isAdmin();
      // 作成時はスキーマバリデーションを強制（不正データ混入防止）
      allow create: if isAdmin() && isValidReservation(request.resource.data);
      // 更新・削除はステータス変更等の部分更新があるためバリデーション不要
      allow update, delete: if isAdmin();
    }

    // [SEC-18] create は Cloud Function 経由のみ
    // [SEC-5]  cancel も Cloud Function 経由のみ（未認証 update 廃止）
    // [SEC-7]  患者向け予約画面（SPA）が未認証で slots を直接読み取るため
    //          公開読み取りを維持。ただし reservationId フィールドが漏洩する
    //          リスクあり — 将来的に Cloud Function 経由の読み取りに移行推奨
    match /slots/{slotId} {
      allow read: if true;
      // 管理者のみ書き込み可
      allow write: if isAdmin();
    }

    // ユーザー設定コレクション（初期パスワード強制変更フラグ等）
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
      // 本人のみ以下フィールドの更新可:
      // - mustChangePassword: 初回パスワード変更完了時
      // - [C2] termsAcceptedAt / privacyAcceptedAt / termsVersion: 利用規約・PP同意時
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'mustChangePassword',
          'termsAcceptedAt',
          'privacyAcceptedAt',
          'termsVersion'
        ]);
    }

    // 診察履歴コレクション（管理者のみ読み書き可能 — 改ざん防止のため更新・削除不可）
    match /visit_histories/{historyId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll([
          'id', 'reservationId', 'name', 'phone', 'date', 'time',
          'completedAt', 'completedBy', 'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 50
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 20
        && request.resource.data.date is string
        && request.resource.data.date.size() == 10;
      allow update, delete: if false;

      // 訂正履歴サブコレクション（CF経由のみ書き込み可能 — APPI第34条対応）
      match /corrections/{correctionId} {
        allow read: if isAdmin();
        allow create, update, delete: if false;
      }
    }

    // 監査ログコレクション（CSVエクスポート等の操作記録）
    match /audit_logs/{logId} {
      allow create: if isAdmin();
      allow read: if isAdmin();
    }

    // 問診票コレクション（患者が予約ID をキーとして書き込み、管理者が読み取り）
    match /questionnaires/{bookingId} {
      // 未認証でも予約IDを知っていれば書き込み可能（予約完了後のフロー）
      allow create: if request.resource.data.keys().hasAll(['reservationId', 'chiefComplaint', 'patientName', 'createdAt'])
        && request.resource.data.reservationId is string
        && request.resource.data.chiefComplaint is string
        && request.resource.data.chiefComplaint.size() <= 1000;
      // 読み取り: 未認証患者が重複送信チェック（qSnap.exists()）に使用するため公開
      // TODO: Cloud Function 経由に移行し isAdmin() に変更（患者情報保護強化）
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // [AUDIT-03] アクセスログコレクション（閲覧トレーサビリティ）
    match /access_logs/{logId} {
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll(['adminUid', 'adminEmail', 'action', 'targetId', 'timestamp'])
        && request.resource.data.adminUid is string
        && request.resource.data.action is string
        && request.resource.data.targetId is string;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // 設定コレクション
    // [SEC-22] list を禁止し get のみ許可（ドキュメントID指定の読み取りのみ）
    match /settings/{settingId} {
      // 院名・PP等の表示のため未認証でも get 可（list は管理者のみ）
      allow get: if true;
      allow list: if isAdmin();
      // 管理者のみ書き込み可
      allow write: if isAdmin();
    }

  }
}
