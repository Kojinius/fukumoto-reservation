rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // デフォルト拒否
    match /{document=**} {
      allow read, write: if false;
    }

    // 管理者判定（Firebase Auth カスタムクレーム）
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // 予約データバリデーション
    function isValidReservation(data) {
      return data.keys().hasAll(['id','name','furigana','date','time','phone','status','createdAt'])
        && data.name     is string && data.name.size()     <= 50
        && data.furigana is string && data.furigana.size() <= 50
        && data.phone    is string && data.phone.size()    <= 20
        && data.date     is string && data.date.size()     == 10
        && data.time     is string && data.time.size()     <= 10
        && data.status   in ['pending','confirmed','cancelled']
        // 任意フィールドの型・長さ検証
        && (!data.keys().hasAny(['email'])         || (data.email is string && data.email.size() <= 200))
        && (!data.keys().hasAny(['zip'])           || (data.zip is string && data.zip.size() <= 8))
        && (!data.keys().hasAny(['address'])       || (data.address is string && data.address.size() <= 200))
        && (!data.keys().hasAny(['symptoms'])      || (data.symptoms is string && data.symptoms.size() <= 1000))
        && (!data.keys().hasAny(['notes'])         || (data.notes is string && data.notes.size() <= 500))
        && (!data.keys().hasAny(['visitType'])     || (data.visitType is string && data.visitType.size() <= 50))
        && (!data.keys().hasAny(['insurance'])     || (data.insurance is string && data.insurance.size() <= 50))
        && (!data.keys().hasAny(['gender'])        || (data.gender is string && data.gender.size() <= 20))
        && (!data.keys().hasAny(['birthdate'])     || (data.birthdate is string && data.birthdate.size() <= 10))
        && (!data.keys().hasAny(['contactMethod']) || (data.contactMethod is string && data.contactMethod.size() <= 50));
    }

    // [SEC-18] 予約コレクション — create は Cloud Function (createReservation) 経由のみ
    match /reservations/{reservationId} {
      // 患者：予約番号（ドキュメントID）による1件読み取り可（IDが事実上のアクセストークン）
      allow get: if request.auth == null;
      // 患者：statusをcancelledに変更するのみ許可（_cancelVerifyで電話番号サーバーサイド検証）
      allow update: if request.auth == null
        && resource.data.status != 'cancelled'
        && request.resource.data.status == 'cancelled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', '_cancelVerify'])
        && request.resource.data._cancelVerify == resource.data.phone;
      // 管理者：読み書きすべて可
      allow read, write: if isAdmin();
    }

    // [SEC-18] スロットコレクション — create 削除、キャンセル時の update のみ許可
    match /slots/{slotId} {
      allow read: if true;
      // 患者：予約キャンセル時のスロット開放（* → cancelled、status変更のみ）
      allow update: if request.auth == null
        && resource.data.status != 'cancelled'
        && request.resource.data.status == 'cancelled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      // 管理者：読み書きすべて可
      allow read, write: if isAdmin();
    }

    // ユーザー設定コレクション（初期パスワード強制変更フラグ等）
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
      // 本人のみ mustChangePassword フィールドの更新可
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mustChangePassword']);
    }

    // 設定コレクション
    match /settings/{settingId} {
      // 院名・PP等の表示のため未認証でも読み取り可
      allow read: if true;
      // 管理者のみ書き込み可
      allow write: if isAdmin();
    }

  }
}
