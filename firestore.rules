rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // デフォルト拒否
    match /{document=**} {
      allow read, write: if false;
    }

    // 管理者判定（Firebase Auth カスタムクレーム）
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // 予約データバリデーション
    function isValidReservation(data) {
      return data.keys().hasAll(['id','name','furigana','date','time','phone','status','createdAt'])
        && data.name     is string && data.name.size()     <= 50
        && data.furigana is string && data.furigana.size() <= 50
        && data.phone    is string && data.phone.size()    <= 20
        && data.date     is string && data.date.size()     == 10
        && data.time     is string
        && data.status   in ['pending','confirmed','cancelled'];
    }

    // 予約コレクション
    match /reservations/{reservationId} {
      // 患者：新規作成のみ（未認証でも可）
      allow create: if request.auth == null
        && isValidReservation(request.resource.data);
      // 患者：予約番号（ドキュメントID）による1件読み取り可（IDが事実上のアクセストークン）
      allow get: if request.auth == null;
      // 患者：statusをcancelledに変更するのみ許可（他フィールドは変更不可）
      allow update: if request.auth == null
        && resource.data.status != 'cancelled'
        && request.resource.data.status == 'cancelled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      // 管理者：読み書きすべて可
      allow read, write: if isAdmin();
    }

    // スロットコレクション（二重予約防止用）
    match /slots/{slotId} {
      // 患者：作成・読み取り可（トランザクション用）
      allow read, create: if request.auth == null;
      // 患者：スロット更新（2パターン許可）
      //   1. キャンセル済みスロットへの再予約（cancelled → pending）
      //   2. 予約キャンセル時のスロット開放（* → cancelled、status変更のみ）
      allow update: if request.auth == null
        && (
          (resource.data.status == 'cancelled'
            && request.resource.data.status == 'pending')
          ||
          (resource.data.status != 'cancelled'
            && request.resource.data.status == 'cancelled'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
        );
      // 管理者：読み書きすべて可
      allow read, write: if isAdmin();
    }

    // 設定コレクション
    match /settings/{settingId} {
      // 院名・PP等の表示のため未認証でも読み取り可
      allow read: if true;
      // 管理者のみ書き込み可
      allow write: if isAdmin();
    }

  }
}
